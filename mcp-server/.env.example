# HubSpot Private App Token
# Create at: HubSpot → Settings → Integrations → Private Apps
# Required scopes: forms (read/write)
HUBSPOT_PRIVATE_APP_TOKEN=pat-na2-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Vercel API Token
# Create at: https://vercel.com/account/tokens
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Project ID (optional - can be passed per-tool)
# Find at: Vercel Dashboard → Project → Settings → General
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Team ID (optional - only needed for team-owned projects)
# Find at: Vercel Dashboard → Team Settings → General
VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxxxxxx
